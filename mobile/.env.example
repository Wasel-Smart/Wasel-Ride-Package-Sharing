# Wasel Mobile Environment Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps API Keys
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=your-ios-key-here
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=your-android-key-here

# Sentry Configuration (Optional)
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Environment
EXPO_PUBLIC_ENV=development

# API Configuration
EXPO_PUBLIC_API_URL=https://api.wasel14.online
EXPO_PUBLIC_API_TIMEOUT=30000

# Feature Flags
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=true
EXPO_PUBLIC_ENABLE_LOCATION_SERVICES=true
EXPO_PUBLIC_ENABLE_ANALYTICS=true

# Debug Settings
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_LOG_LEVEL=info
