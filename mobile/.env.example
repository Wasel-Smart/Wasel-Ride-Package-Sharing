# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API Configuration
EXPO_PUBLIC_API_URL=https://your-project.supabase.co/functions/v1
EXPO_PUBLIC_EDGE_FUNCTION_NAME=make-server-0b1f4071

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OAuth
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Support Contact
EXPO_PUBLIC_SUPPORT_WHATSAPP=962790000000
EXPO_PUBLIC_SUPPORT_EMAIL=support@wasel.jo
EXPO_PUBLIC_SUPPORT_PHONE=962790000000

# Feature Flags
EXPO_PUBLIC_ENABLE_BIOMETRIC_AUTH=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# App Configuration
EXPO_PUBLIC_APP_NAME=Wasel
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_ENVIRONMENT=development
