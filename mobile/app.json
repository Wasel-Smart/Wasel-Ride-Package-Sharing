{
  "expo": {
    "name": "Wasel",
    "slug": "wasel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wasel.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wasel uses your location to find nearby rides and show your position on the map.",
        "NSLocationAlwaysUsageDescription": "Wasel uses your location to update your position as a driver during an active trip."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "com.wasel.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00C8E8",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Wasel needs location access to match you with drivers and track your trip."
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "wasel",
    "extra": {
      "eas": {
        "projectId": "wasel-mobile-project"
      }
    }
  }
}
