dden;\n  border-radius: 20px;\n  background: radial-gradient(circle at top left, rgba(88, 221, 255, 0.07), transparent 34%), linear-gradient(145deg, #10253a 0%, #0b1d2d 100%);\n  border: 1px solid rgba(88, 221, 255, 0.09);\n  box-shadow: 0 10px 32px rgba(0, 0, 0, 0.34), inset 0 1px 0 rgba(88, 221, 255, 0.04);\n  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease, border-color 0.3s ease;\n}\n.wasel-card:hover {\n  transform: translateY(-3px);\n  box-shadow: 0 18px 56px rgba(0, 0, 0, 0.42);\n}\n.wasel-card-orange {\n  border-color: rgba(255, 190, 92, 0.18);\n}\n.wasel-card-orange:hover {\n  border-color: rgba(255, 190, 92, 0.38);\n  box-shadow: 0 12px 40px rgba(255, 190, 92, 0.14);\n}\n.wasel-card-green {\n  border-color: rgba(71, 214, 158, 0.18);\n}\n.wasel-card-green:hover {\n  border-color: rgba(71, 214, 158, 0.38);\n  box-shadow: 0 12px 40px rgba(71, 214, 158, 0.14);\n}\n.wasel-card-cyan {\n  border-color: rgba(88, 221, 255, 0.18);\n}\n.wasel-card-cyan:hover {\n  border-color: rgba(88, 221, 255, 0.38);\n  box-shadow: 0 12px 40px rgba(88, 221, 255, 0.14);\n}\n.wasel-card-purple {\n  border-color: rgba(139, 92, 246, 0.15);\n}\n.wasel-card-purple:hover {\n  border-color: rgba(139, 92, 246, 0.35);\n  box-shadow: 0 12px 40px rgba(139, 92, 246, 0.12);\n}\n.btn-wasel-primary {\n  position: relative;\n  overflow: hidden;\n  background: linear-gradient(135deg, #67e8ff 0%, #38beff 55%, #32d8a6 100%);\n  box-shadow: 0 10px 28px rgba(56, 190, 255, 0.28), 0 1px 0 rgba(255, 255, 255, 0.15) inset;\n  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n  color: #041018;\n  font-weight: 800;\n  border-radius: 14px;\n}\n.btn-wasel-primary:hover {\n  transform: translateY(-2px) scale(1.02);\n  box-shadow: 0 14px 36px rgba(56, 190, 255, 0.36), 0 1px 0 rgba(255, 255, 255, 0.2) inset;\n}\n.btn-wasel-primary:active {\n  transform: scale(0.97);\n}\n.btn-wasel-primary::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gr