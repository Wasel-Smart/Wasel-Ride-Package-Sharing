ale(1);\n    opacity: 0.6;\n  }\n  33% {\n    transform: translate(60px, -40px) scale(1.1);\n    opacity: 0.8;\n  }\n  66% {\n    transform: translate(-40px, 60px) scale(0.95);\n    opacity: 0.5;\n  }\n}\n@keyframes aurora-2 {\n  0%, 100% {\n    transform: translate(0, 0) scale(1.05);\n    opacity: 0.5;\n  }\n  40% {\n    transform: translate(-80px, 50px) scale(0.9);\n    opacity: 0.7;\n  }\n  80% {\n    transform: translate(60px, -70px) scale(1.15);\n    opacity: 0.4;\n  }\n}\n@keyframes aurora-3 {\n  0%, 100% {\n    transform: translate(0, 0) scale(1);\n    opacity: 0.4;\n  }\n  50% {\n    transform: translate(40px, 30px) scale(1.2);\n    opacity: 0.6;\n  }\n}\n@keyframes shimmer-scan {\n  0% {\n    background-position: -200% center;\n  }\n  100% {\n    background-position: 200% center;\n  }\n}\n@keyframes gradient-x {\n  0%, 100% {\n    background-position: 0% center;\n  }\n  50% {\n    background-position: 100% center;\n  }\n}\n@keyframes float {\n  0%, 100% {\n    transform: translateY(0px);\n  }\n  50% {\n    transform: translateY(-10px);\n  }\n}\n@keyframes float-slow {\n  0%, 100% {\n    transform: translateY(0px) rotate(0deg);\n  }\n  50% {\n    transform: translateY(-16px) rotate(2deg);\n  }\n}\n@keyframes glow-teal {\n  0%, 100% {\n    box-shadow: 0 0 20px 0px rgba(0, 200, 232, 0.3);\n  }\n  50% {\n    box-shadow: 0 0 40px 8px rgba(0, 200, 232, 0.5);\n  }\n}\n@keyframes glow-green {\n  0%, 100% {\n    box-shadow: 0 0 20px 0px rgba(0, 200, 117, 0.3);\n  }\n  50% {\n    box-shadow: 0 0 40px 8px rgba(0, 200, 117, 0.5);\n  }\n}\n@keyframes glow-bronze {\n  0%, 100% {\n    box-shadow: 0 0 20px 0px rgba(240, 168, 48, 0.3);\n  }\n  50% {\n    box-shadow: 0 0 40px 8px rgba(240, 168, 48, 0.5);\n  }\n}\n@keyframes orbit {\n  from {\n    transform: rotate(0deg) translateX(120px) rotate(0deg);\n  }\n  to {\n    transform: rotate(360deg) translateX(120px) rotate(-360deg);\n  }\n}\n@keyframes border-glow {\n  0%, 100% {\n    border-color: rgba(4, 173, 191, 0.15);\n  }\n  50% {\n    border-color: rgba(4, 173, 191, 0.55);\n  }\n}\n@keyframes fade-up {\n  from {\n    opacity: 0;\n    transform: translateY(24px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n@keyframes count-shimmer {\n  0% {\n    background-position: -200% center;\n  }\n  100% {\n    background-position: 200% center;\n  }\n}\n@keyframes live-pulse {\n  0%, 100% {\n    opacity: 1;\n    transform: scale(1);\n  }\n  50% {\n    opacity: 0.4;\n    transform: scale(0.8);\n  }\n}\n@keyframes breathe {\n  0%, 100% {\n    transform: scale(1);\n  }\n  50% {\n    transform: scale(1.04);\n  }\n}\n@keyframes ai-pulse {\n  0%, 100% {\n    box-shadow: 0 0 0 0 rgba(4, 173, 191, 0.4), 0 0 12px 2px rgba(4, 173, 191, 0.15);\n  }\n  50% {\n    box-shadow: 0 0 0 4px rgba(4, 173, 191, 0), 0 0 20px 6px rgba(4, 173, 191, 0.25);\n  }\n}\n@keyframes ai-pulse-orange {\n  0%, 100% {\n    box-shadow: 0 0 0 0 rgba(217, 150, 91, 0.4), 0 0 12px 2px rgba(217, 150, 91, 0.15);\n  }\n  50% {\n    box-shadow: 0 0 0 4px rgba(217, 150, 91, 0), 0 0 20px 6px rgba(217, 150, 91, 0.25);\n  }\n}\n@keyframes neon-pulse {\n  0%, 100% {\n    box-shadow: 0 0 5px rgba(4, 173, 191, 0.2), 0 0 20px rgba(4, 173, 191, 0.1);\n  }\n  50% {\n    box-shadow: 0 0 10px rgba(4, 173, 191, 0.4), 0 0 40px rgba(4, 173, 191, 0.2);\n  }\n}\n@keyframes savings-shimmer {\n  0% {\n    background-position: -200% center;\n  }\n  100% {\n    background-position: 200% center;\n  }\n}\n@keyframes glow-border {\n  0%, 100% {\n    border-color: rgba(4, 173, 191, 0.2);\n  }\n  50% {\n    border-color: rgba(4, 173, 191, 0.6);\n  }\n}\n.aurora-1 {\n  animation: aurora-1 12s ease-in-out infinite;\n}\n.aurora-2 {\n  animation: aurora-2 15s ease-in-out infinite;\n}\n.aurora-3 {\n  animation: aurora-3 10s ease-in-out infinite;\n}\n.animate-float {\n  animation: float 4s ease-in-out infinite;\n}\n.animate-float-slow {\n  animation: float-slow 7s ease-in-out infinite;\n}\n.animate-breathe {\n  animation: breathe 4s ease-in-out infinite;\n}\n.animate-orbit {\n  animation: orbit 8s linear infinite;\n}\n.animate-fade-up {\n  animation: fade-up 0.6s ease forwards;\n}\n.glow-teal-anim {\n  animation: glow-teal 3s ease-in-out infinite;\n}\n.glow-green-anim {\n  animation: glow-green 3s ease-in-out infinite;\n}\n.glow-bronze-anim {\n  animation: glow-bronze 3s ease-in-out infinite;\n}\n.ai-glow {\n  animation: ai-pulse 2.5s ease-in-out infinite;\n}\n.ai-glow-orange {\n  animation: ai-pulse-orange 2.5s ease-in-out infinite;\n}\n.live-dot {\n  animation: live-pulse 1.5s ease-in-out infinite;\n}\n.neon-glow {\n  animation: neon-pulse 3s ease-in-out infinite;\n}\n.float-animation {\n  animation: float 3s ease-in-out infinite;\n}\n.glow-border-animation {\n  animation: glow-border 2s ease-in-out infinite;\n}\n.animate-border-glow {\n  animation: border-glow 2.5s ease-in-out infinite;\n}\n.text-gradient-primary {\n  background: linear-gradient(135deg, #00c8e8 0%, #5ee7ff 50%, #00c875 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n.text-gradient-teal {\n  background: linear-gradient(135deg, #00c8e8 0%, #5ee7ff 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n.text-gradient-bronze {\n  background: linear-gradient(135deg, #f0a830 0%, #ffd070 50%, #c8751a 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n.text-gradient-gold {\n  background: linear-gradient(135deg, #f0a830 0%, #ffd070 50%, #c8751a 100%);\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n}\n.savings-shimmer {\n  background: linear-gradient( 90deg, #00c875 0%, #00c8e8 30%, #5ee7ff 50%, #00c8e8 70%, #00c875 100% );\n  background-size: 200% auto;\n  -webkit-background-clip: text;\n  background-clip: text;\n  -webkit-text-fill-color: transparent;\n  animation: savings-shimmer 3s linear infinite;\n}\n.earnin