play: flex;\n  align-items: center;\n  gap: 10px;\n  width: 100%;\n  padding: 10px 14px;\n  border-radius: 12px;\n  font-size: var(--wasel-text-sm);\n  font-weight: var(--wasel-fw-medium);\n  color: rgba(100, 116, 139, 1);\n  transition: background 0.18s ease, color 0.18s ease, transform 0.15s ease;\n  cursor: pointer;\n  text-align: left;\n}\n.sidebar-item:hover {\n  background: var(--wasel-sidebar-item-hover);\n  color: rgba(241, 245, 249, 0.9);\n  transform: translateX(2px);\n}\n[dir='rtl'] .sidebar-item:hover {\n  transform: translateX(-2px);\n}\n.sidebar-item:active {\n  transform: scale(0.98);\n}\n.sidebar-item.active {\n  background: var(--wasel-sidebar-item-active);\n  color: #00c8e8;\n  font-weight: var(--wasel-fw-bold);\n}\n.sidebar-item.active::before {\n  content: '';\n  position: absolute;\n  left: 0;\n  top: 20%;\n  bottom: 20%;\n  width: 3px;\n  border-radius: 0 3px 3px 0;\n  background: var(--wasel-sidebar-active-rail);\n}\n[dir='rtl'] .sidebar-item.active::before {\n  left: auto;\n  right: 0;\n  border-radius: 3px 0 0 3px;\n}\n.sidebar-section-label {\n  padding: 0 14px;\n  margin-bottom: 4px;\n  font-size: 0.6rem;\n  font-weight: var(--wasel-fw-bold);\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: rgba(51, 65, 85, 1);\n}\n.kpi-card {\n  position: relative;\n  border-radius: var(--wasel-radius-xl);\n  overflow: hidden;\n  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;\n}\n.kpi-card:hover {\n  transform: translateY(-3px) scale(1.02);\n}\n.sidebar-divider {\n  height: 1px;\n  margin: 10px 14px;\n  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);\n}\n@keyframes shimmer-sweep {\n  from {\n    transform: translateX(-100%);\n  }\n  to {\n    transform: translateX(200%);\n  }\n}\n@keyframes skeleton-pulse {\n  0%, 100% {\n    opacity: 0.5;\n  }\n  50% {\n    opacity: 0.8;\n  }\n}\n.skeleton-base {\n  position: relative;\n  overflow: hidden;\n  background: rgba(30, 41, 59, 0.5);\n  border-radius: var(--wasel-radius-md);\n}\n.skeleton-base::after {\n  content: '';\n  position: absolute;\n  inset: 0 -100%;\n  background: linear-gradient( 90deg, transparent 0%, rgba(255, 255, 255, 0.05) 40%, rgba(255, 255, 255, 0.09) 50%, rgba(255, 255, 255, 0.05) 60%, transparent 100% );\n  animation: shimmer-sweep 1.8s ease-in-out infinite;\n}\n.sk-line {\n  height: 13px;\n  border-radius: 6px;\n}\n.sk-line-sm {\n  height: 10px;\n  border-radius: 5px;\n}\n.sk-line-lg {\n  height: 18px;\n  border-radius: 8px;\n}\n.sk-circle {\n  border-radius: 9999px;\n}\n.sk-rect {\n  border-radius: var(--wasel-radius-md);\n}\n.sk-card {\n  border-radius: var(--wasel-radius-xl);\n  height: 140px;\n}\n.skeleton-ride-card {\n  border-radius: var(--wasel-radius-xl);\n  background: rgba(17, 27, 46, 0.8);\n  border: 1px solid rgba(255, 255, 255, 0.04);\n  padding: 20px;\n  overflow: hidden;\n  position: relative;\n}\n.skeleton-ride-card::before {\n  content: '';\n  position: absolute;\n  inset: 0 -100%;\n  background: linear-gradient( 90deg, transparent 0%, rgba(255, 255, 255, 0.03) 40%, rgba(255, 255, 255, 0.065) 50%, rgba(255, 255, 255, 0.03) 60%, transparent 100% );\n  animation: shimmer-sweep 2s ease-in-out infinite;\n}\n.surface-0 {\n  background: var(--wasel-surface-0);\n}\n.surface-1 {\n  background: var(--wasel-surface-1);\n}\n.surface-2 {\n  background: var(--wasel-surface-2);\n}\n.surface-3 {\n  background: var(--wasel-surface-3);\n}\n.input-premium {\n  background: rgba(0, 0, 0, 0.25);\n  border: 1px solid rgba(0, 200, 232, 0.1);\n  border-radius: var(--wasel-radius-md);\n  color: #eff6ff;\n  font-size: var(--wasel-text-body);\n  padding: 10px 14px;\n  transition: border-color 0.18s ease, box-shadow 0.18s ease;\n  outline: none;\n  width: 100%;\n}\n.input-premium:focus {\n  border-color: rgba(0, 200, 232, 0.35);\n  box-shadow: 0 0 0 3px rgba(0, 200, 232, 0.12);\n}\n.input-premium::placeholder {\n  color: #4d6a8a;\n}\n.pill {\n  display: inline-flex;