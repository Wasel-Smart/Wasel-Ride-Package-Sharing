{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals", "@testing-library/jest-dom", "vite/client"],
    "noEmit": true
  },
  "include": [
    "src/**/*.d.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "e2e/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "src/supabase/functions"
  ]
}
