tests/
supabase/
playwright.config.ts
vitest.config.ts

# Development files
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build artifacts (except dist)
.vite/
coverage/
dist/
build/
.vercel/
*.tgz
*.zip
*.pdf

# Documentation
docs/
*.md
!README.md

# Git
.git/
.github/

# IDE
.vscode/
.idea/

# Docker
docker/
Dockerfile
docker-compose*.yml

# Kubernetes
infra/
