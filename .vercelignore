# Vercel ignore file
# Keep source/config files available for the remote Vite build and exclude local-only artifacts.

# Local agent/tooling state
.agents/
.claude/
.codex/
.codex_tmp/
.commandcode/
.continue/
.kilo/
actions-runner/

# Development files
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build and test artifacts
build/
dist/
.vite/
coverage/
playwright-report/
test-results/

# Documentation
docs/
*.md
!README.md

# Git
.git/
.github/

# IDE
.vscode/
.idea/

# Docker
docker/
Dockerfile
Dockerfile.dev
docker-compose*.yml

# Kubernetes
infra/

# Non-web app workspace
mobile/
