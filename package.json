  "browserslist": {
    "production": [
      "defaults",
      "iOS >= 12",
      "Safari >= 12",
      "Chrome >= 90",
      "Android >= 8"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks || true",
    "dev": "node scripts/dev-server.mjs",
    "dev:docker": "docker-compose -f docker-compose.dev.yml up",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:migration:list": "supabase migration list --local",
    "health:check": "node -e \"import('./src/utils/healthCheck.ts').then(m => m.performHealthCheck(true).then(console.log))\"",
    "build": "node scripts/check-build-env.mjs && tsc --noEmit && vite build && npm run sync:build-output",
    "vercel-build": "node scripts/check-vercel-env.mjs && tsc --noEmit && vite build",
    "supabase": "supabase",
    "preview": "vite preview",
    "sync:build-output": "node scripts/sync-build-output.mjs",
    "test": "vitest run --maxWorkers=1",
    "test:unit": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --maxWorkers=1",
    "test:e2e": "playwright test",
    "test:e2e:oauth": "playwright test --config playwright.oauth.config.ts",
    "test:load:smoke": "k6 run tests/load/k6-smoke.js",
    "test:load:production": "k6 run tests/load/k6-production.js",
    "verify:contracts": "node scripts/validate-openapi.mjs && node scripts/validate-infra.mjs && node scripts/validate-topology.mjs && node scripts/validate-env-example.mjs && node scripts/validate-production-boundaries.mjs",
    "verify:production-boundaries": "node scripts/validate-production-boundaries.mjs",
    "verify:oauth": "node scripts/verify-oauth-config.mjs",
    "verify:twilio": "node scripts/verify-twilio-config.mjs",
    "verify:live-integrations": "node scripts/verify-live-integrations.mjs",
    "verify:wiring": "node scripts/verify-wiring.mjs",
    "verify:backend-integrations": "npm run verify:contracts && npm run verify:wiring && npm run verify:production-10 && npm run verify:live-integrations",
    "verify:production-10": "node scripts/production-10-gate.mjs",
    "verify:production-10:restore-kind": "node scripts/restore-kind-production-images.mjs",
    "verify:qa-10": "npm run verify:production-10:restore-kind && npm run verify:production-10",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc --noEmit -p tsconfig.tests.json",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "verify:supabase-rollout": "node scripts/verify-supabase-rollout.mjs",
    "verify:auth-providers": "node scripts/validate-production-auth-providers.mjs",
    "extract:vercel-env": "node scripts/extract-vercel-env.mjs",
    "generate:vercel-env": "node scripts/generate-all-vercel-env.mjs",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "verify:ci": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-ci.ps1",
    "verify": "npm run type-check && npm run type-check:tests && npm run lint && npm run verify:contracts && npm run test && npm run build && npm run test:e2e",
    "workers:start": "node -e \"import('./src/platform/worker-framework.ts').then(m => m.workerRegistry.startAll())\"",
    "observability:dashboard": "npm run dev -- --open /ops/observability",
    "telemetry:init": "node -e \"import('./src/platform/telemetry.ts').then(m => m.initWebVitals())\"",
    "health:check:production": "node scripts/verify-live-health.mjs https://wasel14.online/health",
    "mobile:install": "cd mobile && npm install",
    "mobile:android": "cd mobile && npm run android",
    "mobile:ios": "cd mobile && npm run ios",
    "mobile:build": "bash scripts/build-mobile-apps.sh all release",
    "mobile:build:android": "bash scripts/build-mobile-apps.sh android release",
    "mobile:build:ios": "bash scripts/build-mobile-apps.sh ios release",
    "k8s:deploy": "bash scripts/deploy-kubernetes.sh",
    "load:test": "bash scripts/run-load-tests.sh production https://wasel14.online",
    "load:smoke": "bash scripts/run-load-tests.sh smoke https://wasel14.online",
    "load:smoke:node": "node scripts/load-smoke-node.mjs https://wasel14.online/health",
    "validate:10-out-of-10": "node scripts/validate-10-out-of-10.mjs",
    "upgrade:deploy": "node scripts/deploy-to-10.mjs",
    "upgrade:prereq": "node scripts/deploy-to-10.mjs prereq",
    "upgrade:build": "node scripts/deploy-to-10.mjs build",
    "upgrade:status": "node scripts/deploy-to-10.mjs verify"
  }
}
