    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "supabase:migration:list": "supabase migration list --local",
    "health:check": "node -e \"import('./src/utils/healthCheck.ts').then(m => m.performHealthCheck(true).then(console.log))\"",
    "build": "node scripts/check-build-env.mjs && tsc --noEmit && vite build && npm run sync:build-output",
    "vercel-build": "node scripts/check-vercel-env.mjs && tsc --noEmit && vite build",
    "supabase": "supabase",
    "preview": "vite preview",
    "sync:build-output": "node scripts/sync-build-output.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:oauth": "playwright test e2e/oauth.spec.ts",
    "test:load:smoke": "k6 run tests/load/k6-smoke.js",
    "verify:contracts": "node scripts/validate-openapi.mjs && node scripts/validate-infra.mjs && node scripts/validate-topology.mjs && node scripts/validate-env-example.mjs",
    "verify:oauth": "node scripts/verify-oauth-config.mjs",
    "verify:wiring": "node scripts/verify-wiring.mjs",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "verify:supabase-rollout": "node scripts/verify-supabase-rollout.mjs",
    "extract:vercel-env": "node scripts/extract-vercel-env.mjs",
    "generate:vercel-env": "node scripts/generate-all-vercel-env.mjs",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "verify:ci": "npm run type-check && npm run lint && npm run verify:contracts && npm run test:unit && npm run build",
    "verify": "npm run type-check && npm run lint && npm run verify:contracts && npm run test && npm run build && npm run test:e2e"
