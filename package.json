{
  "name": "wasel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Wasel Mobility Platform",
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0 --port 5173",
    "preview": "vite preview",
    "prebuild": "npm run clean",
    "build": "npm run typecheck && vite build",
    "build:analyze": "vite build --mode analyze",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "verify:contracts": "node scripts/validate-openapi.mjs && node scripts/validate-topology.mjs && node scripts/validate-infra.mjs",
    "quality": "npm run lint && npm run typecheck && npm run test:unit",
    "verify:production": "npm run quality && npm run verify:contracts && npm run build",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:db:reset": "supabase db reset",
    "clean": "rimraf node_modules dist coverage .vite",
    "clean:cache": "npm cache clean --force",
    "reinstall": "rimraf node_modules package-lock.json && npm cache clean --force && npm install",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:full-fix": "npm audit fix --force",
    "prepare": "husky",
    "go-live": "npm run verify:production && npm audit --audit-level=high"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/react": "^10.54.0",
    "@stripe/stripe-js": "^9.7.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "motion-dom": "^12.40.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prisma": "^6.19.3",
    "puppeteer-core": "^25.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "qs": "^6.14.0",
    "tough-cookie": "^5.1.2",
    "uuid": "^11.1.0",
    "tar": "7.5.15",
    "undici": "7.25.0",
    "path-to-regexp": "8.4.2",
    "minimatch": "10.2.3",
    "smol-toml": "1.6.1",
    "@eslint/eslintrc": "3.3.1",
    "@tootallnate/once": "3.0.1"
  },
  "packageManager": "npm@10"
}
