    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-resizable-panels": "^2.1.7",
    "react-router": "^7.13.2",
    "recharts": "^2.15.2",
    "sonner": "^2.0.3",
    "supabase": "^2.95.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.3.8",
    "vaul": "^1.1.2",
    "web-vitals": "^5.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.22.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^11.1.6",
    "@size-limit/preset-app": "^11.1.6",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-core": "^4.11.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "size-limit": "^11.1.6",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "@lhci/cli": {
      "inquirer": "^8.2.7",
      "tmp": "^0.2.5"
    },
    "external-editor": {
      "tmp": "^0.2.5"
    }
  },
  "scripts": {
    "dev": "vite",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "build": "tsc --noEmit && vite build && npm run sync:build-output",
    "build:optimized": "tsc --noEmit && vite build && npm run sync:build-output && node scripts/optimize-bundle.mjs",
    "preview": "vite preview",
    "sync:build-output": "node scripts/sync-build-output.mjs",
    "apply:supabase-rollout": "node scripts/apply-supabase-rollout.mjs",
    "seed": "node scripts/run-seeds.mjs",
    "sync:supabase-migration-docs": "node scripts/sync-supabase-migration-docs.mjs",
    "worker:automation": "node scripts/run-automation-worker.mjs",
    "test": "npm run test:node && npm run test:dom && node scripts/merge-vitest-results.mjs vitest-results-node.json vitest-results-dom.json vitest-results.json",
    "test:node": "vitest run --config vitest.config.ts --project=node --reporter=dot --reporter=json --outputFile.json=vitest-results-node.json --silent=passed-only",
    "test:dom": "vitest run --config vitest.config.ts --project=dom --reporter=dot --reporter=json --outputFile.json=vitest-results-dom.json --silent=passed-only",
    "test:watch": "vitest --config vitest.config.ts --reporter=dot --silent=passed-only",
    "test:coverage": "vitest run --config vitest.coverage.config.ts --coverage",
    "playwright:install": "playwright install chromium firefox webkit",
    "playwright:install:chromium": "playwright install chromium",
    "playwright:install:mobile": "playwright install chromium webkit",
    "test:e2e": "npm run playwright:install && playwright test",
    "test:e2e:smoke": "npm run playwright:install:chromium && playwright test --project=chromium-desktop tests/e2e/core-route-smoke.spec.ts tests/e2e/auth-journeys.spec.ts tests/e2e/core-flows.spec.ts tests/e2e/wallet-payments.spec.ts",
    "test:e2e:a11y": "npm run playwright:install:chromium && playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e:mobile": "npm run playwright:install:mobile && playwright test --project=mobile-android-chrome --project=mobile-ios-safari",
    "test:e2e:rtl": "npm run playwright:install:chromium && playwright test tests/e2e/rtl-arabic.spec.ts",
    "test:security": "vitest run tests/unit/utils/security.test.ts tests/unit/utils/security-two-factor.test.ts --reporter=dot --silent=passed-only",
    "test:lhci": "node scripts/collect-lighthouse.mjs",
    "size": "node scripts/check-bundle-budgets.mjs",
    "size:why": "node scripts/check-bundle-budgets.mjs --verbose",
    "check:encoding": "node scripts/check-encoding.mjs",
    "check:ts-strict": "node scripts/check-typescript-strict-mode.mjs",
    "check:domain-boundaries": "node scripts/check-domain-boundaries.mjs",
    "report:quality": "node scripts/generate-quality-report.mjs",
    "verify:quality": "node scripts/verify-quality.mjs",
    "verify:10-out-of-10": "node scripts/verify-10-out-of-10.mjs",
    "type-check": "tsc --noEmit",
    "check:design-system": "node scripts/check-design-system.mjs",
    "check:openapi": "npm run generate:openapi && git diff --exit-code -- docs/openapi",
    "check:translations": "vitest run tests/unit/locales/translation-completeness.test.ts --config vitest.config.ts --reporter=dot --silent=passed-only",
    "lint": "eslint src tests playwright.config.ts vitest.config.ts --ext .ts,.tsx --cache",
    "lint:strict": "npm run lint -- --max-warnings 0",
    "generate:openapi": "node scripts/generate-openapi-specs.mjs",
    "verify:supabase-rollout": "node scripts/verify-supabase-rollout.mjs",
    "verify:auth:production": "node scripts/verify-production-auth.mjs",
    "lint:fix": "eslint src tests playwright.config.ts vitest.config.ts --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "verify": "npm run type-check && npm run check:ts-strict && npm run lint:strict && npm run check:design-system && npm run check:domain-boundaries && npm run check:translations && npm run check:openapi && npm run test && npm run build && npm run size && npm run test:e2e:smoke",
    "verify:full": "npm run verify && npm run test:e2e && npm run test:lhci && npm run test:security",
    "build:production": "node scripts/build-production.mjs",
    "build:analyze": "node scripts/analyze-bundle.mjs",
    "build:secure": "node scripts/fix-log-injections.mjs && npm run build:production",
    "security:fix": "node scripts/fix-log-injections.mjs",
    "security:audit": "npm audit --audit-level=high && npm run test:security",
    "check:deps": "npx depcheck",
    "check:outdated": "npm outdated",
    "type-check:watch": "tsc --noEmit --watch",
    "optimize": "node scripts/optimize-performance.mjs",
    "clean:optimize": "node scripts/detect-dead-code.mjs && node scripts/optimize-performance.mjs",
    "clean": "rimraf dist build coverage .nyc_output",
    "clean:deps": "rimraf node_modules package-lock.json && npm install",
    "ci:verify": "npm run type-check && npm run check:ts-strict && npm run lint:strict && npm run check:design-system && npm run check:domain-boundaries && npm run check:translations && npm run check:openapi && npm run test && npm run build && npm run size && npm run test:e2e:smoke",
    "precommit": "npm run type-check && npm run lint:strict && npm run format:check",
    "prepush": "npm run test && npm run build",
    "production:validate": "node scripts/validate-production-env.mjs",
    "production:deploy": "npm run production:validate && npm run build && vercel --prod",
    "production:health": "node scripts/health-check.mjs --url=$npm_config_url",
    "production:monitor": "node scripts/health-check.mjs --continuous --interval=60",
    "verify:gaps": "node scripts/verify-gaps-fixed.mjs",
    "backup:db": "node scripts/backup-database.mjs --type=full",
    "backup:schema": "node scripts/backup-database.mjs --type=schema",
    "backup:data": "node scripts/backup-database.mjs --type=data"
  }
}
