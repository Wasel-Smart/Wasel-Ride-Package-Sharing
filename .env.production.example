VITE_APP_ENV=production
VITE_APP_URL=https://your-domain.com

# REQUIRED: deploy the edge function before going live.
# Run: supabase functions deploy make-server-0b1f4071 --project-ref <ref>
# Leaving VITE_ALLOW_DIRECT_SUPABASE_FALLBACK=false (correct for prod) means
# the app WILL break if this function is not deployed.
VITE_EDGE_FUNCTION_NAME=make-server-0b1f4071

VITE_ENABLE_SYNTHETIC_DATA=false
VITE_ENABLE_SYNTHETIC_TRIPS=false
VITE_ALLOW_DIRECT_SUPABASE_FALLBACK=false
VITE_ALLOW_LOCAL_PERSISTENCE_FALLBACK=false

# Copy the remaining shared keys from `.env.example`.
