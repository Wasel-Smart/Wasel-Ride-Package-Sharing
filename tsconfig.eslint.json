{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": false
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/wasel-routes.tsx",
    "src/**/*.d.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "coverage",
    "playwright-report",
    "test-results"
  ]
}
