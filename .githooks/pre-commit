#!/bin/sh
# Pre-commit hook: blocks secrets, env files, and AI tool artefacts.
# Activate with: git config core.hooksPath .githooks

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

for f in $(git diff --cached --name-only); do
  # Block real .env files
  case "$f" in
    .env|.env.local|.env.development|.env.test|.env.production|.env.staging)
      echo "${RED}BLOCKED:${NC} $f \u2014 env files must not be committed. Use .env.example instead."
      BLOCKED=1
      ;;
  esac

  # Block certificates and private keys
  case "$f" in
    *.pem|*.key|*.p8|*.p12|*.pfx|*.crt|*.cer)
      echo "${RED}BLOCKED:${NC} $f \u2014 certificates and private keys must never be committed."
      BLOCKED=1
      ;;
  esac

  # Block AI tool workspace artefacts
  case "$f" in
    skills-lock.json)
      echo "${YELLOW}BLOCKED:${NC} $f \u2014 AI tool artefact, not project code."
      BLOCKED=1
      ;;
  esac
done

if [ "$BLOCKED" = "1" ]; then
  echo ""
  echo "Commit aborted. Unstage blocked files with: git reset HEAD <file>"
  exit 1
fi

exit 0
