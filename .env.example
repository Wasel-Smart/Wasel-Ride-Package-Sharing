# Frontend public runtime
VITE_APP_ENV=development
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_EDGE_FUNCTION_NAME=make-server-0b1f4071
# Optional overrides when your API is not hosted at /functions/v1/<name>
# VITE_EDGE_FUNCTIONS_BASE_URL=https://your-project.supabase.co/functions/v1
# VITE_API_URL=https://api.example.com/functions/v1/make-server-0b1f4071
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_SUPPORT_EMAIL=support@example.com
VITE_SUPPORT_WHATSAPP_NUMBER=962790000000
VITE_SUPPORT_PHONE_NUMBER=962790000000
VITE_SUPPORT_SMS_NUMBER=962790000000
VITE_BUSINESS_ADDRESS=Amman, Jordan
VITE_BUSINESS_ADDRESS_AR=Amman, Jordan
VITE_FOUNDER_NAME=Wasel founder
VITE_AUTH_CALLBACK_PATH=/app/auth/callback
VITE_ENABLE_TWO_FACTOR_AUTH=false
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_SMS_NOTIFICATIONS=true
VITE_ENABLE_WHATSAPP_NOTIFICATIONS=true
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_key
VITE_SENTRY_DSN=
VITE_APP_URL=http://localhost:3000
VITE_PRODUCTION_APP_URL=https://your-production-domain.com
VITE_APP_NAME=Wasel
VITE_ENABLE_DEMO_DATA=false
VITE_ENABLE_SYNTHETIC_TRIPS=false
VITE_ALLOW_DIRECT_SUPABASE_FALLBACK=false
VITE_ALLOW_LOCAL_PERSISTENCE_FALLBACK=false

# Local Supabase stack and local tooling
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_GRAPHQL_URL=http://127.0.0.1:54321/graphql/v1
SUPABASE_STORAGE_S3_URL=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_MCP_URL=http://127.0.0.1:54321/mcp
STUDIO_URL=http://127.0.0.1:54323
MAILPIT_URL=http://127.0.0.1:54324
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_PUBLISHABLE_KEY=your-local-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-local-secret-key
S3_ACCESS_KEY=your-local-s3-access-key
S3_SECRET_KEY=your-local-s3-secret-key
S3_REGION=local

# Hosted project and server-side integrations
SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_PROJECT_PUBLISHABLE_KEY=your-project-publishable-key
SUPABASE_PROJECT_SECRET_KEY=your-project-secret-key
SUPABASE_LEGACY_ANON_JWT=your-legacy-anon-jwt-if-still-needed
SUPABASE_LEGACY_SERVICE_ROLE_JWT=your-legacy-service-role-jwt-if-still-needed
GOOGLE_MAPS_API_KEY=your-google-maps-server-key-if-different
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID_ALT=optional-second-google-client-id.apps.googleusercontent.com
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_API_KEY_SID=your-twilio-api-key-sid
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret
# Required by the current Supabase function runtime for SMS and WhatsApp sends.
TWILIO_MESSAGING_SERVICE_SID=your-twilio-messaging-service-sid
TWILIO_SMS_FROM=+15555555555
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email providers for Supabase Edge Functions
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Wasel <notifications@example.com>
RESEND_REPLY_TO_EMAIL=support@example.com
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=notifications@example.com

# Operational secrets for server-side runtimes
COMMUNICATION_WORKER_SECRET=replace-with-a-long-random-secret
AUTOMATION_WORKER_SECRET=replace-with-a-different-long-random-secret
COMMUNICATION_WEBHOOK_TOKEN=replace-with-a-long-random-token
COMMUNICATION_MAX_ATTEMPTS=5
COMMUNICATION_PROCESS_INLINE=false

# E2E Testing credentials (for Playwright tests)
E2E_TEST_EMAIL=demo@wasel.jo
E2E_TEST_PASSWORD=demo123
