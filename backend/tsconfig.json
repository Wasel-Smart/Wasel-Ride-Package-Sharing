{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "services/**/*",
    "../src/domain/**/*",
    "../src/platform/event-broker-redis.ts",
    "../src/platform/event-broker-redis-production.ts",
    "../src/platform/telemetry.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
