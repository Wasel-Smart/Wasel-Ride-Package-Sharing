VITE_APP_ENV=development
VITE_APP_URL=http://localhost:3000
VITE_EDGE_FUNCTION_NAME=make-server-0b1f4071

# In development the edge function is often not deployed locally.
# Keeping the fallback enabled lets ride search and trip creation
# work directly against Supabase without a running edge function.
VITE_ENABLE_SYNTHETIC_DATA=false
VITE_ENABLE_SYNTHETIC_TRIPS=false
VITE_ALLOW_DIRECT_SUPABASE_FALLBACK=true
VITE_ALLOW_LOCAL_PERSISTENCE_FALLBACK=false

# Copy the remaining shared keys from `.env.example`.
