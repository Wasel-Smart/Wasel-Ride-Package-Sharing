{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Run baseline-browser-mapping",
            "runtimeExecutable": "baseline-browser-mapping",
            "cwd": "${workspaceFolder}",
            "args": []
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Run semver",
            "runtimeExecutable": "semver",
            "cwd": "${workspaceFolder}/node_modules/@mapbox/node-pre-gyp",
            "args": []
        },
        {
            "name": "SWA: Run with-supabase-app",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:4280",
            "preLaunchTask": "swa: start with-supabase-app",
            "webRoot": "${workspaceFolder}/with-supabase-app",
            "timeout": 30000
        },
        {
            "name": "SWA: Run Wdoubleme",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:4280",
            "preLaunchTask": "swa: start Wdoubleme",
            "webRoot": "${workspaceFolder}/",
            "timeout": 30000
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}