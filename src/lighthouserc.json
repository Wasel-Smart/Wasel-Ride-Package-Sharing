{
  "ci": {
    "collect": {
      "staticDistDir": "dist",
      "isSinglePageApplication": true,
      "url": [
        "http://localhost:4173"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-gpu"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance":     ["error", { "minScore": 0.90 }],
        "categories:accessibility":   ["error", { "minScore": 0.95 }],
        "categories:best-practices":  ["error", { "minScore": 0.90 }],
        "categories:seo":             ["error", { "minScore": 0.92 }],
        "categories:pwa":             ["warn",  { "minScore": 0.80 }],

        "first-contentful-paint":     ["warn",  { "maxNumericValue": 2000 }],
        "largest-contentful-paint":   ["error", { "maxNumericValue": 2800 }],
        "cumulative-layout-shift":    ["error", { "maxNumericValue": 0.10 }],
        "total-blocking-time":        ["warn",  { "maxNumericValue": 400  }],
        "speed-index":                ["warn",  { "maxNumericValue": 3200 }],
        "interactive":                ["warn",  { "maxNumericValue": 4000 }],

        "uses-responsive-images":     "off",
        "offscreen-images":           "warn",
        "uses-webp-images":           "warn",
        "uses-optimized-images":      "warn",
        "efficient-animated-content": "warn",
        "uses-rel-preconnect":        "warn",
        "uses-long-cache-ttl":        "warn",
        "render-blocking-resources":  "warn",
        "unused-javascript":          "warn",
        "unused-css-rules":           "warn",

        "color-contrast":             "error",
        "aria-valid-attr":            "error",
        "button-name":                "error",
        "image-alt":                  "error",
        "link-name":                  "error",
        "document-title":             "error",
        "html-has-lang":              "error",
        "meta-description":           "error",
        "canonical":                  "warn",

        "is-on-https":                "error",
        "no-vulnerable-libraries":    "error",
        "csp-xss":                    "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
