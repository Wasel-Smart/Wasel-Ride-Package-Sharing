{
  "meta": {
    "name": "Wasel Brand System",
    "version": "2026-04-11",
    "source": "Unified teal-network identity — single source of truth",
    "canonical": "brand-theme.css is the runtime CSS layer; this file is the design record"
  },
  "color": {
    "bg": "#07111B",
    "bgAlt": "#0C1724",
    "bgDeep": "#050C15",
    "surface": "#101D2C",
    "surfaceAlt": "#172738",
    "primary": "#19E7BB",
    "primaryDeep": "#0BC3A0",
    "primaryLight": "#DCFFF8",
    "accent": "#48CFFF",
    "success": "#A2FFE7",
    "text": "#E9F5F7",
    "textSub": "rgba(198,223,227,0.82)",
    "textMuted": "rgba(170,191,196,0.58)",
    "border": "rgba(25,231,187,0.16)",
    "borderStrong": "rgba(25,231,187,0.34)",
    "error": "#FF646A",
    "warning": "#65E1FF"
  },
  "typography": {
    "fontSans": "Plus Jakarta Sans",
    "fontArabic": "Cairo",
    "fontDisplay": "Space Grotesk",
    "scale": {
      "h1": "3.25rem",
      "h2": "2.5rem",
      "h3": "2rem",
      "h4": "1.6rem",
      "h5": "1.32rem",
      "h6": "1.125rem",
      "body": "0.92rem",
      "bodyLarge": "1rem",
      "caption": "0.76rem",
      "meta": "0.66rem"
    }
  },
  "spacing": {
    "base": 4,
    "grid": 8,
    "steps": [4, 8, 12, 16, 20, 24, 28, 32, 40, 48, 64, 80, 96]
  },
  "radius": {
    "sm": 10,
    "md": 14,
    "lg": 18,
    "xl": 22,
    "xxl": 28,
    "pill": 9999
  },
  "shadow": {
    "card": "0 18px 44px rgba(3,8,14,0.3)",
    "raised": "0 24px 56px rgba(2,6,12,0.36)",
    "hero": "0 34px 80px rgba(2,6,12,0.44)",
    "glowPrimary": "0 18px 50px rgba(25,231,187,0.22)"
  },
  "gradient": {
    "primary": "linear-gradient(135deg, #DCFFF8 0%, #19E7BB 44%, #48CFFF 100%)",
    "accent": "linear-gradient(135deg, #65E1FF 0%, #A2FFE7 100%)",
    "signal": "linear-gradient(135deg, #A2FFE7 0%, #19E7BB 44%, #48CFFF 100%)"
  }
}
