{
  "title": "Wasel Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "title": "API P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Ride Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ride_request_count[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Package Delivery Success Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(package_delivery_success_total[5m])) / sum(rate(package_delivery_attempt_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Notification Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "notification_queue_depth",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_rejections[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
